{% extends "Master/MenuBghTemplate.html.twig" %}

{% block bodyHeaderOptions %}
    <br/>
    <br/>
    <br/>
    <br/>
    <br/>
{% endblock %}

{% block body %}
    <form id="fModelo369" method="post">
        {{ formToken() }}
        <input type="hidden" name="action" id="action" value=""/>
        <div class="container" style="margin-top: -90px;">
            <div class="row">
                <div class="col-12">
                    <div class="card shadow mb-3">
                        <div class="card-body">
                            <h1 class="h3 mb-1">
                                <i class="{{ fsc.getPageData().icon }} me-2"></i> {{ fsc.title }}
                            </h1>
                            <p class="text-muted mb-4">{{ trans('model-369-p') }}</p>
                            <div class="row g-2">
                                <div class="col-sm-6 col-md-4">
                                    {{ trans('exercise') }}
                                    <select name="codejercicio" class="form-select mb-3">
                                        {% for value, label in fsc.getEjercicios() %}
                                            <option value="{{ value }}"{{ value == fsc.codejercicio ? ' selected' : '' }}>
                                                {{ label }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-sm-6 col-md-4">
                                    {{ trans('regime') }}
                                    <select name="regime" id="regime" class="form-select mb-3">
                                        {% for value, label in fsc.getRegimeOptions() %}
                                            <option value="{{ value }}"{{ value == fsc.regime ? ' selected' : '' }}>
                                                {{ label }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-sm-6 col-md-4">
                                    {{ trans('period') }}
                                    <select name="periodo" id="periodo" class="form-select mb-3">
                                        {% for value, label in fsc.getPeriodOptions() %}
                                            <option value="{{ value }}"{{ value == fsc.periodo ? ' selected' : '' }}>
                                                {{ label }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-spin-action flex-fill">
                                <i class="fa-solid fa-eye me-1"></i> {{ trans('view-data') }}
                            </button>
                            <button type="button" onclick="downloadCsv369();"
                                    class="btn btn-secondary btn-spin-action flex-fill">
                                <i class="fa-solid fa-download me-1"></i> {{ trans('download-csv') }}
                            </button>
                        </div>
                    </div>

                    {% if fsc.searched %}
                        {% if fsc.data is not empty %}
                            <div class="card shadow mb-3">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead>
                                            <tr>
                                                <th>{{ trans('destination-country') }}</th>
                                                <th class="text-end">{{ trans('vat-rate') }}</th>
                                                <th class="text-end">{{ trans('tax-base') }}</th>
                                                <th class="text-end">{{ trans('vat-amount') }}</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for row in fsc.data %}
                                                <tr>
                                                    <td>{{ fsc.getCountryName(row.codpais) }}</td>
                                                    <td class="text-end">{{ number(row.iva) }} %</td>
                                                    <td class="text-end">{{ money(row.baseimponible) }}</td>
                                                    <td class="text-end">{{ money(row.cuotaiva) }}</td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                        <tfoot>
                                            <tr class="fw-bold table-light">
                                                <td>{{ trans('total') }}</td>
                                                <td></td>
                                                <td class="text-end">{{ money(fsc.totalBase) }}</td>
                                                <td class="text-end">{{ money(fsc.totalCuota) }}</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        {% else %}
                            <div class="alert alert-warning">
                                {{ trans('no-data-for-period') }}
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        </div>
    </form>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        const periodOptions369 = {
            quarters: [
                {value: "T1", label: "{{ trans('first-trimester')|e('js') }}"},
                {value: "T2", label: "{{ trans('second-trimester')|e('js') }}"},
                {value: "T3", label: "{{ trans('third-trimester')|e('js') }}"},
                {value: "T4", label: "{{ trans('fourth-trimester')|e('js') }}"}
            ],
            months: [
                {value: "01", label: "{{ trans('january')|e('js') }}"},
                {value: "02", label: "{{ trans('february')|e('js') }}"},
                {value: "03", label: "{{ trans('march')|e('js') }}"},
                {value: "04", label: "{{ trans('april')|e('js') }}"},
                {value: "05", label: "{{ trans('may')|e('js') }}"},
                {value: "06", label: "{{ trans('june')|e('js') }}"},
                {value: "07", label: "{{ trans('july')|e('js') }}"},
                {value: "08", label: "{{ trans('august')|e('js') }}"},
                {value: "09", label: "{{ trans('september')|e('js') }}"},
                {value: "10", label: "{{ trans('october')|e('js') }}"},
                {value: "11", label: "{{ trans('november')|e('js') }}"},
                {value: "12", label: "{{ trans('december')|e('js') }}"}
            ]
        };

        function downloadCsv369() {
            document.getElementById('action').value = 'download-csv';
            document.getElementById('fModelo369').submit();
            document.getElementById('action').value = '';
        }

        document.getElementById('regime').addEventListener('change', function () {
            const periodoSelect = document.getElementById('periodo');
            const options = this.value === 'ioss' ? periodOptions369.months : periodOptions369.quarters;
            periodoSelect.innerHTML = '';
            options.forEach(function (opt) {
                const o = document.createElement('option');
                o.value = opt.value;
                o.textContent = opt.label;
                periodoSelect.appendChild(o);
            });
        });
    </script>
{% endblock %}
